{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.mjs": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.mjs"
    }
  ]
}